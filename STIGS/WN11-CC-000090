$regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Group Policy\{35378EAC-683F-11D2-A89A-00C04FBBCFA2}"

# Create the registry path if it doesn't exist
if(-not(Test-Path $regPath)) {
    New-Item -Path $regPath -Force | Out-Null
    }
# Set "Configure registry policy processing" to ""Enabled" and select the option "Process even if the Group Policy objects have not changed".
    New-ItemProperty -Path $regPath -Name "NoGPOListChanges" -PropertyType DWord -Value 0 -Force | Out-Null

# Display configured value
    Get-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Group Policy\{35378EAC-683F-11D2-A89A-00C04FBBCFA2}" -Name NoGPOListChanges
