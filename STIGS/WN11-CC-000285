.USAGE
    Put any usage instructions here.
    Example syntax:
    PS C:\> .\STIG-ID-WN11-CC-000285.ps1 

$regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows NT\Terminal Services"

# Create the registry path if it doesn't exist
if(-not(Test-Path $regPath)) {
    New-Item -Path $regPath -Force | Out-Null
    }
# Set "fEncryptRPCTraffic" to "Enabled"
    New-ItemProperty -Path $regPath -Name "fEncryptRPCTraffic" -PropertyType DWord -Value 1 -Force | Out-Null

# Display configured value
    Get-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows NT\Terminal Services" -Name fEncryptRPCTraffic
