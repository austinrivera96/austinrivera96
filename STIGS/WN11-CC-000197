.USAGE
    Put any usage instructions here.
    Example syntax:
    PS C:\> .\STIG-ID-WN11-CC-000197.ps1 


$regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent"

# Ensure the key exists
if (-not (Test-Path $regPath)) {
    New-Item -Path $regPath -Force | Out-Null
}

New-ItemProperty -Path $regPath -Name "DisableWindowsConsumerFeatures" -PropertyType DWord -Value 1  -Force | Out-Null

#
Get-ItemProperty -Path $regPath -Name "DisableWindowsConsumerFeatures"
